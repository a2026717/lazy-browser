<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- 顶部导航栏 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:background="#FFFFFF"
            android:elevation="2dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="书架"
                android:textSize="20sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/searchInput"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:hint="搜索书名..."
                android:textSize="14sp"
                android:background="@drawable/bg_search_box"
                android:paddingHorizontal="12dp"
                android:singleLine="true"
                android:visibility="gone"
                android:layout_marginEnd="8dp" />

            <ImageButton
                android:id="@+id/btnSearch"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_refresh"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="搜索" />

            <ImageButton
                android:id="@+id/btnSwitchLayout"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_grid"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="切换布局" />
        </LinearLayout>

        <!-- 继续阅读卡片 -->
        <LinearLayout
            android:id="@+id/continueCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_continue_card"
            android:padding="14dp"
            android:layout_margin="12dp"
            android:visibility="gone">

            <TextView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="▶"
                android:textSize="18sp"
                android:gravity="center"
                android:background="@drawable/bg_play_btn" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginHorizontal="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="继续阅读"
                    android:textSize="11sp"
                    android:textColor="#1A73E8" />

                <TextView
                    android:id="@+id/continueTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="书名"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/continueChapter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="上次读到..."
                    android:textSize="12sp"
                    android:textColor="#888"
                    android:maxLines="1"
                    android:ellipsize="end" />
            </LinearLayout>

            <ImageButton
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_arrow_forward"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="继续" />
        </LinearLayout>

        <!-- 书籍列表/网格 -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/bookRecycler"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:padding="12dp" />

            <!-- 空状态 -->
            <LinearLayout
                android:id="@+id/emptyView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📚"
                    android:textSize="56sp"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="书架空空如也"
                    android:textSize="16sp"
                    android:textColor="#999" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="打开小说 → 点「阅读模式」→ 自动入架"
                    android:textSize="13sp"
                    android:textColor="#BBB"
                    android:layout_marginTop="6dp" />
            </LinearLayout>
        </FrameLayout>

    </LinearLayout>

</FrameLayout>
